{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["dataset", "analytics_as_of", "as_of", "version", "summary", "records"],
  "properties": {
    "dataset": { "const": "person_reconciliation" },
    "analytics_as_of": { "type": "string" },
    "as_of": { "type": "string" },
    "version": { "type": "integer" },
    "summary": { "type": "object" },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["address", "slug", "display_name", "identity_source", "identity_confidence", "repo_value", "site_value", "chain_value", "resolved_value", "reconciliation_status", "evidence_urls"],
        "properties": {
          "address": { "type": "string" },
          "slug": { "type": "string" },
          "display_name": { "type": "string" },
          "identity_source": { "type": "string" },
          "identity_confidence": { "type": "string" },
          "repo_value": { "type": "object" },
          "site_value": { "type": "object" },
          "chain_value": { "type": "object" },
          "resolved_value": { "type": "object" },
          "reconciliation_status": { "type": "string" },
          "evidence_urls": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
