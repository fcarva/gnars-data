  "properties": {
    "dataset": { "const": "treasury_flows" },
    "as_of": { "type": "string" },
    "version": { "type": "integer" },
    "routes": { "type": "array", "items": { "type": "object" } },
    "windows": { "type": "array", "items": { "type": "object" } },
    "proposal_routes": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": false
}
