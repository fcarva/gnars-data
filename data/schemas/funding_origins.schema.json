{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["dataset", "as_of", "version", "records"],
  "properties": {
    "dataset": {
      "const": "funding_origins"
    },
    "as_of": {
      "type": "string"
    },
    "version": {
      "type": "integer"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "funding_source_id",
          "title",
          "source_kind",
          "status",
          "requested_amount",
          "recipient",
          "proposal_chain",
          "tags",
          "notes"
        ],
        "properties": {
          "funding_source_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "source_kind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "requested_amount": {
            "type": "object",
            "required": ["currency", "amount"],
            "properties": {
              "currency": {
                "type": "string"
              },
              "amount": {
                "type": "number"
              },
              "usd_estimate_hint": {
                "type": ["number", "null"]
              }
            },
            "additionalProperties": false
          },
          "recipient": {
            "type": "object",
            "required": ["label", "address"],
            "properties": {
              "label": {
                "type": "string"
              },
              "address": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "proposal_chain": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["stage", "platform", "proposal_ref", "url"],
              "properties": {
                "stage": {
                  "type": "string"
                },
                "platform": {
                  "type": "string"
                },
                "proposal_ref": {
                  "type": "string"
                },
                "proposed_at": {
                  "type": ["string", "null"]
                },
                "status": {
                  "type": ["string", "null"]
                },
                "url": {
                  "type": "string"
                },
                "summary": {
                  "type": "string"
                },
                "governance": {
                  "type": "object",
                  "required": ["for_votes", "against_votes", "abstain_votes", "quorum"],
                  "properties": {
                    "for_votes": {
                      "type": ["number", "null"]
                    },
                    "against_votes": {
                      "type": ["number", "null"]
                    },
                    "abstain_votes": {
                      "type": ["number", "null"]
                    },
                    "quorum": {
                      "type": ["number", "null"]
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
