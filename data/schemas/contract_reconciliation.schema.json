{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["dataset", "analytics_as_of", "as_of", "version", "summary", "records"],
  "properties": {
    "dataset": { "const": "contract_reconciliation" },
    "analytics_as_of": { "type": "string" },
    "as_of": { "type": "string" },
    "version": { "type": "integer" },
    "summary": { "type": "object" },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["contract_id", "ecosystem", "network", "address", "kind", "label", "status", "repo_value", "site_value", "chain_value", "resolved_value", "reconciliation_status", "evidence_urls"],
        "properties": {
          "contract_id": { "type": "string" },
          "ecosystem": { "type": "string" },
          "network": { "type": "string" },
          "address": { "type": "string" },
          "kind": { "type": "string" },
          "label": { "type": "string" },
          "status": { "type": "string" },
          "repo_value": { "type": "object" },
          "site_value": { "type": "object" },
          "chain_value": { "type": "object" },
          "resolved_value": { "type": "object" },
          "reconciliation_status": { "type": "string" },
          "evidence_urls": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
